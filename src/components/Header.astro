---
import Link from '@/components/Link.astro'
import ThemeToggle from '@/components/ThemeToggle.astro'
import { NAV_LINKS, SITE } from '@/consts'

interface Props {
  isHome?: boolean
}

const { isHome = false } = Astro.props
---

<div>
  <div
    class:list={[
      'mx-auto flex items-center gap-4 px-4 py-3',
      isHome ? 'max-w-5xl justify-end' : 'max-w-3xl justify-between',
    ]}
  >
    {
      !isHome && (
        <Link href="/" class="flex shrink-0 items-center justify-center gap-3">
          <img
            src="/static/profile.jpeg"
            alt=""
            width="32"
            height="32"
            class="size-8 shrink-0 rounded-full object-cover sm:size-9"
          />
          <span class="hidden h-full text-lg leading-none font-medium min-[400px]:block">
            {SITE.title}
          </span>
        </Link>
      )
    }
    <div class="flex items-center gap-4">
      <nav class="flex items-center gap-4 text-sm sm:gap-6">
        {
          NAV_LINKS.map((item) => (
            <Link
              href={item.href}
              class="text-foreground/60 hover:text-foreground capitalize transition-colors"
            >
              {item.label}
            </Link>
          ))
        }
      </nav>
      <ThemeToggle transition:persist />
    </div>
  </div>
</div>
